# Flue / server
PORT=3583
FLUE_DB_PATH=./data/flue.db
THERAPIST_APP_DB_PATH=./data/therapist-app.db

# Main local model
THERAPIST_MODEL=ollama/gemma4:12b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional OpenAI Platform API (separate billing from ChatGPT/Codex)
OPENAI_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
PUBLIC_BASE_URL=

# Hindsight memory
HINDSIGHT_BASE_URL=http://localhost:8888
HINDSIGHT_API_KEY=
HINDSIGHT_RECALL_BUDGET=mid
HINDSIGHT_REFLECT_ENABLED=false

# Local OpenAI-compatible speech-to-text server (Speaches)
STT_BASE_URL=http://localhost:8000
STT_MODEL=Systran/faster-whisper-small
STT_API_KEY=
STT_LANGUAGE=
STT_TIMEOUT_MS=180000

# Optional behavior
THERAPIST_LOG_LEVEL=info
