{
  "name": "therapist",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source, self-hosted therapy agent built with Flue, Hindsight, Ollama, Telegram, and evidence-informed Agent Skills.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=22.19.0",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "flue dev --target node",
    "build": "flue build --target node",
    "start": "node dist/server.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:skills": "tsx scripts/validate-skills.ts",
    "doctor": "tsx scripts/doctor.ts",
    "telegram:set-webhook": "tsx scripts/set-telegram-webhook.ts",
    "check": "pnpm validate:skills && pnpm typecheck && pnpm test",
    "ci": "pnpm check && pnpm build"
  },
  "dependencies": {
    "@flue/runtime": "1.0.0-beta.9",
    "@flue/telegram": "1.0.0-beta.1",
    "@vectorize-io/hindsight-client": "0.8.5",
    "grammy": "1.45.1",
    "hono": "4.12.22",
    "js-yaml": "4.1.1",
    "just-bash": "3.0.1",
    "valibot": "1.1.0"
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.9",
    "@types/js-yaml": "4.0.9",
    "@types/node": "22.15.29",
    "tsx": "4.19.2",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
